# =====================================================
# Bluewin - 환경변수 예시
# 실제 값을 채워 .env.local 로 복사한 뒤 사용 (절대 커밋 금지)
# =====================================================

# --- Supabase ---
# Supabase 프로젝트 URL (예: https://xxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon key (public, 브라우저 노출 OK)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key (서버 전용, 절대 브라우저 노출 금지)
SUPABASE_SERVICE_ROLE_KEY=

# --- 주민번호 암호화 (pgcrypto pgp_sym_encrypt 대칭키) ---
# 충분히 긴 임의 문자열 권장 (예: openssl rand -base64 32)
SUPABASE_SSN_ENCRYPTION_KEY=

# --- App ---
# 배포 후 앱 URL (선택, 메일/리다이렉트용)
NEXT_PUBLIC_APP_URL=
